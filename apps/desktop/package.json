{
  "name": "@cypheria/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.mjs",
  "scripts": {
    "build": "pnpm build:main && pnpm build:preload && pnpm build:renderer && pnpm typecheck",
    "build:main": "tsdown --config tsdown.config.mjs",
    "build:preload": "tsdown --config tsdown.preload.config.mjs",
    "build:renderer": "vite build --config vite.config.ts",
    "check": "pnpm typecheck",
    "dev": "pnpm build:main && pnpm build:preload && electron .",
    "dev:renderer": "vite dev --config vite.config.ts --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@cypheria/codex-bridge": "workspace:*",
    "@cypheria/db": "workspace:*",
    "@cypheria/ipc": "workspace:*",
    "@cypheria/policy-engine": "workspace:*",
    "@cypheria/runtime": "workspace:*",
    "@cypheria/ui": "workspace:*",
    "@cypheria/wallet-core": "workspace:*",
    "@cypheria/web3-browser": "workspace:*",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-start": "^1.168.14",
    "jotai": "^2.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.0",
    "tsdown": "^0.22.0",
    "vite": "^8.0.14"
  }
}
