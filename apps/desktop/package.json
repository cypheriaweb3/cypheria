{
  "name": "@cypheria/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.mjs",
  "scripts": {
    "build": "pnpm build:main && pnpm typecheck",
    "build:main": "tsdown --config tsdown.config.mjs",
    "check": "pnpm typecheck",
    "dev": "pnpm build:main && electron .",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@cypheria/codex-bridge": "workspace:*",
    "@cypheria/db": "workspace:*",
    "@cypheria/ipc": "workspace:*",
    "@cypheria/policy-engine": "workspace:*",
    "@cypheria/runtime": "workspace:*",
    "@cypheria/ui": "workspace:*",
    "@cypheria/wallet-core": "workspace:*",
    "@cypheria/web3-browser": "workspace:*"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "tsdown": "^0.22.0"
  }
}
