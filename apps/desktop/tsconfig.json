{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["renderer/src/*"]
    },
    "rootDir": ".",
    "types": ["node", "vite/client"]
  },
  "include": [
    "ipc/**/*.ts",
    "main/**/*.ts",
    "preload/**/*.ts",
    "renderer/**/*.ts",
    "renderer/**/*.tsx",
    "vite.config.ts"
  ],
  "exclude": ["dist"]
}
